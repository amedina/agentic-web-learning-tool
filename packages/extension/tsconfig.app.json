{
	"extends": "@google-awlt/shared-config/typescript/react-library",
	"compilerOptions": {
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"types": ["jest", "@testing-library/jest-dom", "chrome"],
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"@google-awlt/engine-core": ["../engine-core/src/index.ts"],
			"@google-awlt/engine-extension": [
				"../engine-extension/src/index.ts"
			]
		}
	},
	"include": [
		"src",
		"tests/setupTests.d.ts",
		"../design-system/src/**/*.(ts|tsx)",
		"../engine-core/src/**/*.(ts|tsx|ts)",
		"../engine-extension/src/**/*.(ts|tsx|ts)"
	]
}
