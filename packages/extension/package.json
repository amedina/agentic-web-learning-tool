{
  "name": "@google-awlt/extension",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "predev": "rimraf ../../dist/extension",
    "dev": "concurrently \"pnpm run dev:engine-core\" \"pnpm run dev:engine-extension\" \"pnpm run dev:engine-web\" \"pnpm run dev:workflow-ui\" \"pnpm run dev:contentScript\" \"pnpm run dev:extension\"",
    "dev:engine-web": "pnpm --filter @google-awlt/engine-web dev",
    "dev:workflow-ui": "pnpm --filter @google-awlt/workflow-ui dev",
    "dev:contentScript": "cross-env NODE_ENV=development node scripts/contentScript.config.ts --watch",
    "dev:extension": "cross-env NODE_ENV=development vite build --watch --config vite.config.ts",
    "dev:engine-core": "pnpm --filter @google-awlt/engine-core dev",
    "dev:engine-extension": "pnpm --filter @google-awlt/engine-extension dev",
    "prebuild": "rimraf ../../dist/extension",
    "build": "pnpm run build:engine-core && pnpm run build:engine-extension && pnpm run build:engine-web && pnpm run build:table && pnpm run build:workflow-ui && tsc -b && concurrently \"pnpm run build:contentScript\" \"pnpm run build:extension\"",
    "build:workflow-ui": "pnpm --filter @google-awlt/workflow-ui build",
    "build:contentScript": "cross-env NODE_ENV=production node scripts/contentScript.config.ts",
    "build:extension": "cross-env NODE_ENV=production vite build --config vite.config.ts",
    "build:table": "pnpm --filter @google-awlt/table build",
    "build:engine-core": "pnpm --filter @google-awlt/engine-core build",
    "build:engine-extension": "pnpm --filter @google-awlt/engine-extension build",
    "build:engine-web": "pnpm --filter @google-awlt/engine-web build",
    "check-types": "tsc -b -noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "jest --config='./tests/jest.config.js' --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui"
  },
  "dependencies": {
    "@assistant-ui/react": "0.11.51",
    "@google-awlt/chatbot": "workspace:*",
    "@google-awlt/chrome-ai-playground": "workspace:*",
    "@google-awlt/common": "workspace:*",
    "@google-awlt/design-system": "workspace:*",
    "@google-awlt/engine-core": "workspace:*",
    "@google-awlt/engine-extension": "workspace:*",
    "@google-awlt/engine-web": "workspace:*",
    "@google-awlt/mcp-inspector": "workspace:*",
    "@google-awlt/table": "workspace:*",
    "@google-awlt/workflow-ui": "workspace:*",
    "@mcp-b/extension-tools": "0.2.3",
    "@mcp-b/react-webmcp": "^2.0.9",
    "@mcp-b/transports": "1.2.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/vite": "^4.1.12",
    "@xyflow/react": "^12.9.3",
    "lucide-react": "^0.577.0",
    "p-queue": "^7.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.33.0",
    "@google-awlt/shared-config": "workspace:*",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/react-vite": "^9.1.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.27",
    "@types/dom-chromium-ai": "^0.0.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-storybook": "^9.1.3",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^7.0.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.55.1",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5",
    "storybook": "^9.1.3",
    "ts-jest": "^29.4.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.11",
    "vite-plugin-static-copy": "^3.1.4",
    "vite-plugin-svgr": "^4.5.0"
  }
}
