{
  "extends": "@google-awlt/shared-config/typescript/react-library",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "lib": ["dom", "ESNext"],
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./node_modules/@types"],
    "types": ["node", "jest"],
    "resolveJsonModule": true
  },
  "include": [
    "src",
    "tests",
    "**/*.test.ts",
    "**/*.test.tsx",
    "node_modules/jest-extended/types/index.d.ts"
  ],
  "exclude": ["dist", "build", "node_modules"]
}
