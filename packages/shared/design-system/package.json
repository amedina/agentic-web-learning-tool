{
  "name": "@google-awlt/design-system",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css",
    "./*": {
      "import": "./src/components/*/index.tsx",
      "require": "./src/components/*/index.tsx"
    }
  },
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "dev": "concurrently pnpm run \"dev:styles\" \"pnpm run dev:components\"",
    "prebuild": "rimraf dist dist-types",
    "build": "pnpm run build:styles & npm run build:components",
    "lint": "eslint .",
    "format": "prettier . --write",
    "test": "jest --config='tests/jest.config.js'"
  },
  "dependencies": {
    "@assistant-ui/react": "0.11.51",
    "@assistant-ui/react-markdown": "0.11.8",
    "@assistant-ui/react-syntax-highlighter": "0.11.4",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@google-awlt/common": "workspace:*",
    "@google-awlt/table": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@storybook/test": "^8.6.15",
    "acorn": "^8.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/types": "^7.29.0",
    "@google-awlt/shared-config": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@storybook/react-vite": "^9.1.3",
    "@tailwindcss/cli": "^4.1.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/acorn": "^6.0.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^7.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.10",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.9.2"
  }
}
