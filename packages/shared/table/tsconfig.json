{
  "extends": "@google-awlt/shared-config/typescript/react-library",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "rootDir": ".",
    "outDir": "./dist/table",
    "lib": ["dom", "ES2015"],
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./node_modules/@types"],
    "types": ["chrome", "node", "jest", "react", "react-dom"],
    "verbatimModuleSyntax": false
  },
  "include": ["src"],
  "exclude": [
    "**/tests/**/*.ts",
    "**/tests/**/*.tsx",
    "**/stories/**",
    "dist",
    "build",
    "node_modules"
  ]
}
