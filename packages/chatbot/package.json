{
  "name": "@google-awlt/chatbot",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "predev": "rimraf ../../dist",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "prebuild": "rimraf dist dist-types",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "jest --config='./tests/jest.config.js' --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.53",
    "@ai-sdk/google": "2.0.63",
    "@ai-sdk/openai": "^2.0.77",
    "@ai-sdk/provider": "^2.0.0",
    "@assistant-ui/react": "0.11.51",
    "@assistant-ui/react-ai-sdk": "1.1.19",
    "@google-awlt/common": "workspace:*",
    "@google-awlt/design-system": "workspace:*",
    "@mcp-b/react-webmcp": "^2.0.9",
    "@mcp-b/transports": "1.2.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@radix-ui/react-icons": "^1.3.2",
    "ai": "^5.0.104",
    "assistant-stream": "0.2.46",
    "json-schema": "^0.4.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.33.0",
    "@google-awlt/shared-config": "workspace:*",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/chrome": "^0.1.27",
    "@types/dom-chromium-ai": "^0.0.13",
    "@types/jest": "^29.5.14",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-extended": "^7.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
