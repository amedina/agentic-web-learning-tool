{
  "extends": "@google-awlt/shared-config/typescript/react-library",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "lib": ["dom", "ESNext"],
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["jest", "chrome", "dom-chromium-ai"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": "."
  },
  "include": [
    "src",
    "tests/setupTests.d.ts",
    "node_modules/jest-extended/types/index.d.ts",
    "node_modules/@types/chrome/index.d.ts",
    "node_modules/@types/dom-chromium-ai/index.d.ts"
  ],
  "exclude": [
    "dist",
    "build",
    "tests",
    "node_modules",
    "src/contentScript/assets/webmcp-polyfill.js"
  ]
}
