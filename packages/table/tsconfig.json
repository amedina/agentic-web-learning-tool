{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "composite": false,
    "strict": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "baseUrl": ".",
    "paths": {
      "@google-awlt/common": ["../common/src/index.ts"]
    },
    "types": ["chrome", "node", "jest", "react"]
  },
  "exclude": [
    "**/tests/**/*.ts",
    "**/tests/**/*.tsx",
    "**/dist/**/*",
    "**/dist-types/**/*",
    "**/stories/**"
  ],
  "references": [],
  "include": ["src/**/*", "../common/src/**/*"]
}
