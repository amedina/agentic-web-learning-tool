{
  "extends": "@google-awlt/shared-config/typescript/react-library",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "lib": ["dom", "ES2015"],
    "sourceMap": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@google-awlt/common": ["../common/src/index.ts"]
    },
    "typeRoots": ["./node_modules/@types"],
    "types": ["chrome", "node", "jest", "react", "react-dom"],
    "verbatimModuleSyntax": false
  },
  "include": ["src"],
  "exclude": [
    "**/tests/**/*.ts",
    "**/tests/**/*.tsx",
    "**/stories/**",
    "dist",
    "build",
    "node_modules"
  ]
}
