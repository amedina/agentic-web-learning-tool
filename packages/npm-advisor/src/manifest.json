{
  "name": "NPM Advisor",
  "description": "NPM Advisor Extension",
  "version": "0.0.1",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "js": ["contentScript/contentScript.js"],
      "matches": [
        "*://www.npmjs.com/package/*",
        "*://github.com/*/*/blob/*/package.json"
      ]
    }
  ],
  "host_permissions": [
    "*://registry.npmjs.org/*",
    "*://api.github.com/*",
    "*://bundlephobia.com/*",
    "*://raw.githubusercontent.com/*"
  ]
}
