{
  "name": "NPM Advisor",
  "description": "NPM Advisor Extension",
  "version": "1.0.1",
  "manifest_version": 3,
  "action": {
    "default_title": "Click to open sidepanel"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "js": ["contentScript/contentScript.js"],
      "matches": [
        "*://www.npmjs.com/package/*",
        "*://github.com/*/*/blob/*/package.json"
      ]
    }
  ],
  "permissions": ["storage", "activeTab", "unlimitedStorage", "sidePanel"],
  "host_permissions": [
    "*://registry.npmjs.org/*",
    "*://api.github.com/*",
    "*://bundlephobia.com/*",
    "*://raw.githubusercontent.com/*"
  ]
}
