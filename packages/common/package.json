{
  "name": "@google-awlt/common",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "prebuild": "rimraf dist dist-types",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "format": "prettier . --write",
    "test": "jest --config='tests/jest.config.js'"
  },
  "dependencies": {
    "lodash-es": "^4.17.22",
    "use-context-selector": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@google-awlt/shared-config": "workspace:*",
    "babel-jest": "^30.2.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "jest-extended": "^7.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.10",
    "typescript": "5.9.2"
  }
}
